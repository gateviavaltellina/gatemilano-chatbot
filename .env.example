# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Meta API
WA_PHONE_NUMBER_ID=1021019861105099
WA_ACCESS_TOKEN=EAA...
WA_VERIFY_TOKEN=gate_whatsapp_verify_2025
WA_BUSINESS_ACCOUNT_ID=959741779797746

# Meta app secret — verifica firma webhook (X-Hub-Signature-256).
# Lascialo vuoto per disabilitare la verifica (sconsigliato in produzione).
META_APP_SECRET=

# Instagram DM
# @gatemilano (ID già impostato come default in config.py)
IG_GATEMILANO_TOKEN=EAA...
# @gatesardinia (ID già impostato come default in config.py)
IG_GATESARDINIA_TOKEN=EAA...

# Xceed (stessa chiave di ~/.claude/credentials/xceed_api_key.txt)
XCEED_API_KEY=...

# Agent staff nei gruppi WhatsApp (Cloud API Groups): group_id abilitati (CSV).
# Default chiuso: vuoto = l'agent di gruppo non risponde in nessun gruppo.
# Il group_id si recupera dai log al primo messaggio inviato nel gruppo.
# WA_GROUP_ALLOWLIST=

# Persistenza stato conversazioni (history, human takeover) tra i riavvii.
# Punta a un volume montato persistente, es. su Railway PERSIST_DIR=/data.
# Vuoto = disabilitato (stato solo in memoria, azzerato a ogni deploy).
# PERSIST_DIR=/data

# Opzionali (default ok)
# MODEL=claude-sonnet-4-6
# RAG_TOP_K=5
# MAX_HISTORY=8
# PORT=8000
