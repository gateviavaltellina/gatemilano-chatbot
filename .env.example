# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Meta API
WA_PHONE_NUMBER_ID=1021019861105099
WA_ACCESS_TOKEN=EAA...
WA_VERIFY_TOKEN=gate_whatsapp_verify_2025
WA_BUSINESS_ACCOUNT_ID=959741779797746

# Meta app secret — verifica firma webhook (X-Hub-Signature-256).
# Lascialo vuoto per disabilitare la verifica (sconsigliato in produzione).
META_APP_SECRET=

# Secret per il webhook Sanity (POST /webhook/sanity) — sync immediato alla
# pubblicazione di un evento. Configura lo stesso valore nel webhook del Sanity Studio
# (header X-Webhook-Secret, o in URL ?key=). Vuoto = endpoint non protetto.
SANITY_WEBHOOK_SECRET=

# Token API Sanity in SOLA LETTURA (sanity.io/manage → project → API → Tokens,
# ruolo Viewer). Se impostato, il bot vede anche gli eventi in BOZZA (non ancora
# pubblicati), come lo staff in Studio. Vuoto = solo eventi pubblicati.
SANITY_API_TOKEN=

# Instagram DM
# @gatemilano (ID già impostato come default in config.py)
IG_GATEMILANO_TOKEN=EAA...
# @gatesardinia (ID già impostato come default in config.py)
IG_GATESARDINIA_TOKEN=EAA...

# Xceed (stessa chiave di ~/.claude/credentials/xceed_api_key.txt)
XCEED_API_KEY=...

# Agent staff nei gruppi WhatsApp (Cloud API Groups): group_id abilitati (CSV).
# Default chiuso: vuoto = l'agent di gruppo non risponde in nessun gruppo.
# Il group_id si recupera dal canale Discord dedicato (o dai log) al primo messaggio.
# WA_GROUP_ALLOWLIST=

# Canale Discord dedicato all'agent di gruppo (group_id + attività).
# Preferito: webhook URL (robusto). In alternativa: channel id (post via bot).
# DISCORD_GROUP_WEBHOOK_URL=
# DISCORD_GROUP_CHANNEL_ID=

# Persistenza stato conversazioni (history, human takeover) tra i riavvii.
# Punta a un volume montato persistente, es. su Railway PERSIST_DIR=/data.
# Vuoto = disabilitato (stato solo in memoria, azzerato a ogni deploy).
# PERSIST_DIR=/data

# Opzionali (default ok)
# MODEL=claude-sonnet-4-6
# RAG_TOP_K=5
# MAX_HISTORY=8
# PORT=8000
